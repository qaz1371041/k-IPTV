from concurrent.futures import ThreadPoolExecutor, as_completed
import urllib3
urllib3.disable_warnings()

def check_stream(url, timeout=5):
    """快速检测流地址是否可达"""
    try:
        r = requests.get(url, stream=True, timeout=timeout, verify=False)
        if r.status_code == 200:
            # 判断是否为视频流（可选）
            content_type = r.headers.get('Content-Type', '')
            if 'video' in content_type or 'octet-stream' in content_type or 'mpegurl' in content_type:
                return True
            # 如果没有明确标识，读一小段数据判断
            chunk = r.iter_content(1024).__next__()
            return len(chunk) > 0
    except:
        return False

def filter_valid_channels(channels, max_workers=50):
    valid = []
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        future_to_ch = {executor.submit(check_stream, ch['url']): ch for ch in channels}
        for future in as_completed(future_to_ch):
            ch = future_to_ch[future]
            if future.result():
                valid.append(ch)
    return valid
